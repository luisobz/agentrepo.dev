# =========================================================================
# AgentRepo.dev — Environment Variables Example
# Duplicate this file as '.env' and fill in your local/secret keys.
# =========================================================================

# --- 1. Ports & URLs (Internal Development) ---
WEB_PORT=3000
ADMIN_PORT=3001
BACKEND_WEB_PORT=4000
BACKEND_AI_PORT=4001

# Public API URL for Frontend consumption (tRPC)
NEXT_PUBLIC_API_URL=http://localhost:4000

# BFF URL to call AI services internally
BACKEND_AI_URL=http://localhost:4001
INTERNAL_API_SECRET=your_internal_api_secret_key_here

# --- 2. Database (Prisma / Supabase / Postgres) ---
# For local development (Docker PostgreSQL):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentrepo?schema=public"

# For production/deployed environment (Supabase):
# DATABASE_URL="postgresql://postgres:[pass]@db.[project].supabase.co:5432/postgres?pgbouncer=true"

# --- 3. Authentication (Better Auth / NextAuth) ---
# Random 32-character string for signing auth tokens
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
ADMIN_PASSWORD=your_admin_password_here

# --- 4. AI & LLM (DeepSeek via LangChain) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# --- 5. LLM Observability & Monitoring (Langfuse) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- 6. Email Delivery (Spacemail SMTP via Nodemailer) ---
SPACEMAIL_HOST=mail.spacemail.com
SPACEMAIL_PORT=465
SPACEMAIL_USER=agent@agentrepo.dev
SPACEMAIL_PASS=your_spacemail_password_here

# --- 7. Object Storage (Cloudflare R2 via AWS SDK S3) ---
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=agentrepo-assets
R2_PUBLIC_URL=https://assets.agentrepo.dev

# --- 8. GitHub Integration (for Agent Syncing) ---
# GitHub Personal Access Token (PAT) with repo scopes
GITHUB_TOKEN=ghp_...
