{
  "name": "agentrepo.dev",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "nx dev web",
    "dev:admin": "nx dev admin",
    "dev:api": "nx serve backend-web",
    "dev:ai": "nx serve backend-ai",
    "dev:all": "nx run-many -t dev serve -p web admin backend-web backend-ai",
    "build:web": "nx build web",
    "build:admin": "nx build admin",
    "build:api": "nx build backend-web",
    "build:ai": "nx build backend-ai",
    "build:all": "nx run-many -t build --all",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist .nx",
    "clean:full": "pnpm clean && rm -rf pnpm-lock.yaml",
    "reinstall": "pnpm clean && pnpm install",
    "reinstall:full": "pnpm clean:full && pnpm install",
    "lint": "nx run-many -t lint --all",
    "lint:verbose": "nx run-many -t lint --all --output-style=stream",
    "test": "nx run-many -t test --all",
    "test:verbose": "nx run-many -t test --all --output-style=stream",
    "verify": "nx run-many -t lint,test --all",
    "verify:verbose": "nx run-many -t lint,test --all --output-style=stream",
    "db:up": "bash infra/database/db-up.sh",
    "db:down": "sudo docker compose down",
    "db:generate": "nx run database:generate",
    "db:migrate": "nx run database:migrate-dev",
    "db:migrate:deploy": "nx run database:migrate-deploy",
    "db:studio": "nx run database:studio",
    "db:seed": "nx run database:seed",
    "postinstall": "nx run database:generate"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint-react/eslint-plugin": "^5.8.3",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "22.7.2",
    "@nx/eslint-plugin": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/nest": "22.7.2",
    "@nx/next": "22.7.2",
    "@nx/react": "22.7.2",
    "@nx/vite": "22.7.2",
    "@nx/vitest": "22.7.2",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "20.19.9",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "~4.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^17.0.5",
    "nx": "22.7.2",
    "prettier": "~3.6.2",
    "prisma": "^7.8.0",
    "tslib": "^2.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.40.0",
    "unplugin-swc": "^1.5.9",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  }
}