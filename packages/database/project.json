{
  "name": "database",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/database/src",
  "projectType": "library",
  "tags": [
    "scope:backend"
  ],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm prisma generate --config=packages/database/prisma.config.ts",
        "cwd": "."
      }
    },
    "migrate-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm prisma migrate dev --config=packages/database/prisma.config.ts",
        "cwd": "."
      }
    },
    "migrate-deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm prisma migrate deploy --config=packages/database/prisma.config.ts",
        "cwd": "."
      }
    },
    "studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm prisma studio --config=packages/database/prisma.config.ts",
        "cwd": "."
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm prisma db seed --config=prisma.config.ts",
        "cwd": "packages/database"
      }
    }
  }
}
