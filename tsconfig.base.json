{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@agentrepo/domain": [
        "./packages/domain/src/index.ts"
      ],
      "@agentrepo/application": [
        "./packages/application/src/index.ts"
      ],
      "@agentrepo/infrastructure": [
        "./packages/infrastructure/src/index.ts"
      ],
      "@agentrepo/config": [
        "./packages/config/src/index.ts"
      ],
      "@agentrepo/trpc": [
        "./packages/trpc/src/index.ts"
      ],
      "@agentrepo/trpc/schemas": [
        "./packages/trpc/src/schemas.ts"
      ],
      "@agentrepo/trpc/auth": [
        "./packages/trpc/src/auth.ts"
      ],
      "@agentrepo/ui": [
        "./packages/ui/src/index.ts"
      ],
      "@agentrepo/ui/*": [
        "./packages/ui/src/*"
      ],
      "@agentrepo/avatar": [
        "./packages/avatar/src/index.ts"
      ],
      "@agentrepo/avatar/*": [
        "./packages/avatar/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}